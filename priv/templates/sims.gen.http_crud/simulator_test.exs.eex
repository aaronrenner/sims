defmodule <%= @module %> do
  use ExUnit.Case, async: true

  alias <%= @sim_namespace %>

  test "simulator starts successfully" do
    sim = start_supervised!(<%= @sim_namespace_basename %>)
    req = build_req(sim)

    response = Req.get!(req, url: "/status")

    assert response.body == "Up!"
    assert response.status == 200
  end

  test "allows for closing and reopening a connection" do
    sim = start_supervised!(<%= @sim_namespace_basename %>)
    req = build_req(sim)

    <%= @sim_namespace_basename %>.down(sim)

    assert {:error, %Req.TransportError{reason: :econnrefused}} =
             Req.request(req, url: "/status")

    <%= @sim_namespace_basename %>.up(sim)

    assert Req.get!(req, url: "/status").status == 200
  end

  test "requires an API token" do
    sim = start_supervised!(<%= @sim_namespace_basename %>)
    {:ok, account} = <%= @sim_namespace_basename %>.create_account(sim)
    req = build_req(sim)

    assert Req.get!(req, url: "/<%= @plural_model_name %>").status == 401

    resp = req |> attach_account_auth(account) |> Req.get!(url: "/<%= @plural_model_name %>")

    assert resp.status == 200
    assert %{"<%= @plural_model_name %>" => []} = resp.body
  end

  describe "simulator business logic" do
    test "<%= @model_name %> crud" do
      sim = start_supervised!(<%= @sim_namespace_basename %>)
      {:ok, account} = <%= @sim_namespace_basename %>.create_account(sim)
      req = sim |> build_req() |> attach_account_auth(account)

      assert resp =
               Req.post!(req,
                 url: "/<%= @plural_model_name %>",
                 json: %{"first_name" => "Joe", "last_name" => "Smith"}
               )

      assert resp.status == 201
      assert %{"id" => id, "first_name" => "Joe", "last_name" => "Smith"} = resp.body

      assert %{status: 200, body: body} = Req.get!(req, url: "/<%= @plural_model_name %>/#{id}")
      assert %{"id" => ^id, "first_name" => "Joe", "last_name" => "Smith"} = body

      assert %{status: 200, body: body} = Req.get!(req, url: "/<%= @plural_model_name %>")

      assert %{"<%= @plural_model_name %>" => [%{"id" => ^id, "first_name" => "Joe", "last_name" => "Smith"}]} =
               body

      assert %{status: 200, body: body} =
               Req.patch!(req, url: "/<%= @plural_model_name %>/#{id}", json: %{"first_name" => "Jim"})

      assert %{"id" => ^id, "first_name" => "Jim", "last_name" => "Smith"} = body

      assert %{status: 204} = Req.delete!(req, url: "/<%= @plural_model_name %>/#{id}")

      assert %{status: 404} = Req.get!(req, url: "/<%= @plural_model_name %>/#{id}")

      assert %{status: 404} =
               Req.patch!(req, url: "/<%= @plural_model_name %>/#{id}", json: %{"first_name" => "Jim"})

      assert %{status: 404} = Req.delete!(req, url: "/<%= @plural_model_name %>/#{id}")

      assert %{status: 200, body: %{"<%= @plural_model_name %>" => []}} = Req.get!(req, url: "/<%= @plural_model_name %>")
    end

    test "<%= @plural_model_name %> are returned in the order they are inserted" do
      sim = start_supervised!(<%= @sim_namespace_basename %>)
      {:ok, account} = <%= @sim_namespace_basename %>.create_account(sim)
      req = sim |> build_req() |> attach_account_auth(account)

      <%= @sim_namespace_basename %>.create_<%= @model_name %>(sim, account.id, first_name: "<%= @model_name %> 1")
      <%= @sim_namespace_basename %>.create_<%= @model_name %>(sim, account.id, first_name: "<%= @model_name %> 2")
      <%= @sim_namespace_basename %>.create_<%= @model_name %>(sim, account.id, first_name: "<%= @model_name %> 3")

      assert %{status: 200, body: body} = Req.get!(req, url: "/<%= @plural_model_name %>")

      assert get_in(body, ["<%= @plural_model_name %>", Access.all(), "first_name"]) ==
               ["<%= @model_name %> 1", "<%= @model_name %> 2", "<%= @model_name %> 3"]
    end

    test "<%= @plural_model_name %> are separated by account" do
      sim = start_supervised!(<%= @sim_namespace_basename %>)
      {:ok, account_1} = <%= @sim_namespace_basename %>.create_account(sim)
      <%= @sim_namespace_basename %>.create_<%= @model_name %>(sim, account_1.id, first_name: "<%= @model_name %>")
      account_1_req = sim |> build_req() |> attach_account_auth(account_1)

      {:ok, account_2} = <%= @sim_namespace_basename %>.create_account(sim)
      account_2_req = sim |> build_req() |> attach_account_auth(account_2)

      assert %{status: 200, body: %{"<%= @plural_model_name %>" => [_]}} =
               Req.get!(account_1_req, url: "/<%= @plural_model_name %>")

      assert %{status: 200, body: %{"<%= @plural_model_name %>" => []}} = Req.get!(account_2_req, url: "/<%= @plural_model_name %>")
    end
  end

  describe "triggering errors" do
    test "globally" do
      sim = start_supervised!(<%= @sim_namespace_basename %>)
      req = build_req(sim)

      <%= @sim_namespace_basename %>.trigger_internal_server_errors(sim, :all)

      assert Req.get!(req, url: "/<%= @plural_model_name %>").status == 500
      assert Req.get!(req, url: "/status").status == 500
      assert Req.get!(req, url: "/<%= @plural_model_name %>/abc123").status == 500

      <%= @sim_namespace_basename %>.clear_triggered_responses(sim)

      assert Req.get!(req, url: "/status").status == 200
      assert Req.get!(req, url: "/<%= @plural_model_name %>").status == 401
    end

    test "per endpoint" do
      sim = start_supervised!(<%= @sim_namespace_basename %>)
      {:ok, account} = <%= @sim_namespace_basename %>.create_account(sim)
      req = sim |> build_req() |> attach_account_auth(account)

      <%= @sim_namespace_basename %>.trigger_internal_server_errors(sim, :create_<%= @model_name %>)

      assert %{status: 500} =
               Req.post!(req,
                 url: "/<%= @plural_model_name %>",
                 json: %{"first_name" => "Joe", "last_name" => "Smith"}
               )

      assert %{status: 200, body: %{"<%= @plural_model_name %>" => []}} = Req.get!(req, url: "/<%= @plural_model_name %>")

      <%= @sim_namespace_basename %>.trigger_invalid_responses(sim, :list_<%= @plural_model_name %>)

      assert %{status: 200, body: "Invalid"} = Req.get!(req, url: "/<%= @plural_model_name %>")
    end
  end

  defp build_req(sim) do
    Req.new(base_url: <%= @sim_namespace_basename %>.base_url(sim), retry: false)
  end

  defp attach_account_auth(req, account) do
    Req.Request.merge_options(req, auth: {:basic, "#{account.id}:#{account.token}"})
  end
end
